{
  "version": "1.0",
  "mcp_name": "Norwegian Energy Regulation MCP",
  "tests": [
    {
      "id": "no-energy-001",
      "category": "search",
      "description": "Search regulations for 'energi'",
      "tool": "no_energy_search_regulations",
      "input": { "query": "energi" },
      "assertions": { "result_not_empty": true, "min_results": 1 }
    },
    {
      "id": "no-energy-002",
      "category": "data_retrieval",
      "description": "Get regulation by reference (Energiloven)",
      "tool": "no_energy_get_regulation",
      "input": { "reference": "LOV-1990-06-29-50" },
      "assertions": { "result_not_empty": true }
    },
    {
      "id": "no-energy-003",
      "category": "search",
      "description": "Search grid codes for 'frekvens'",
      "tool": "no_energy_search_grid_codes",
      "input": { "query": "frekvens" },
      "assertions": { "result_not_empty": true, "min_results": 1 }
    },
    {
      "id": "no-energy-004",
      "category": "data_retrieval",
      "description": "Get grid code by document ID",
      "tool": "no_energy_get_grid_code",
      "input": { "document_id": 2 },
      "assertions": { "result_not_empty": true }
    },
    {
      "id": "no-energy-005",
      "category": "search",
      "description": "Search decisions for 'inntektsramme'",
      "tool": "no_energy_search_decisions",
      "input": { "query": "inntektsramme" },
      "assertions": { "result_not_empty": true, "min_results": 1 }
    },
    {
      "id": "no-energy-006",
      "category": "meta_tool",
      "description": "About tool returns server metadata",
      "tool": "no_energy_about",
      "input": {},
      "assertions": { "result_not_empty": true }
    },
    {
      "id": "no-energy-007",
      "category": "negative_test",
      "description": "Non-existent regulation reference handles gracefully",
      "tool": "no_energy_get_regulation",
      "input": { "reference": "NONEXISTENT-REF-999" },
      "assertions": { "handles_gracefully": true }
    },
    {
      "id": "no-energy-008",
      "category": "negative_test",
      "description": "Non-existent grid code ID handles gracefully",
      "tool": "no_energy_get_grid_code",
      "input": { "document_id": 99999 },
      "assertions": { "handles_gracefully": true }
    },
    {
      "id": "no-energy-009",
      "category": "search",
      "description": "Search regulations with regulator filter",
      "tool": "no_energy_search_regulations",
      "input": { "query": "sikkerhet", "regulator": "dsb" },
      "assertions": { "result_not_empty": true, "min_results": 1 }
    },
    {
      "id": "no-energy-010",
      "category": "search",
      "description": "Search regulations with type filter",
      "tool": "no_energy_search_regulations",
      "input": { "query": "forskrift", "type": "forskrift" },
      "assertions": { "result_not_empty": true, "min_results": 1 }
    },
    {
      "id": "no-energy-011",
      "category": "search",
      "description": "Search grid codes by code_type",
      "tool": "no_energy_search_grid_codes",
      "input": { "query": "balanse", "code_type": "balancing" },
      "assertions": { "result_not_empty": true }
    },
    {
      "id": "no-energy-012",
      "category": "cross_reference",
      "description": "Search decisions for methodology approvals",
      "tool": "no_energy_search_decisions",
      "input": { "query": "tariffering", "decision_type": "methodology" },
      "assertions": { "result_not_empty": true, "min_results": 1 }
    }
  ]
}
